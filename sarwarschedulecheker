// EXCEL PARSER
// ══════════════════════════════════════════
function parseExcel(buffer){
  const wb=XLSX.read(buffer,{type:'array',cellDates:true});
  const ws=wb.Sheets[wb.SheetNames[0]];
  const rows=XLSX.utils.sheet_to_json(ws,{raw:false,dateNF:'yyyy-mm-dd'});
  if(!rows.length) throw new Error('Excel sheet is empty');
  const keys=Object.keys(rows[0]);
  const find=(...opts)=>{
    for(const o of opts){const k=keys.find(k=>k.toLowerCase().replace(/[\s_\-\.]+/g,'').includes(o.toLowerCase().replace(/[\s_\-\.]+/g,'')));if(k) return k;}
    return null;
  };
  const C={
    id:find('activityid','actid','taskid','id','code'),
    name:find('activityname','taskname','name','description','activity'),
    dur:find('duration','dur','days'),
    es:find('earlystart','startdate','start','plannedstart'),
    ef:find('earlyfinish','finishdate','finish','plannedfinish'),
    tf:find('totalfloat','float','tf'),
    stat:find('status','state'),
    pct:find('percentcomplete','percent','pctcomplete','pcomplete','progress','%'),
    pred:find('predecessors','pred','predecessor'),
    wbs:find('wbs','workbreakdown','discipline','area'),
    bls:find('baselinestart','blstart','origstart'),
    blf:find('baselinefinish','blfinish','origfinish'),
  };
  const activities=rows.map((r,i)=>{
    const actId=C.id?r[C.id]||('A'+String(i+1).padStart(4,'0')):'A'+String(i+1).padStart(4,'0');
    const name=C.name?r[C.name]||'(unnamed)':'Row '+(i+1);
    const dur=C.dur?parseFloat(r[C.dur])||0:0;
    const tf=C.tf?parseFloat(r[C.tf]):null;
    const pct=C.pct?parseFloat(r[C.pct])||0:0;
    const rawStat=(C.stat?r[C.stat]||'':'').toLowerCase();
    let status='Not started';
    if(rawStat.includes('complet')||rawStat.includes('done')||pct===100) status='Completed';
    else if(rawStat.includes('progress')||rawStat.includes('active')||rawStat.includes('started')||pct>0) status='In progress';
    return{
      id:actId,actId,name,
      wbs:C.wbs?r[C.wbs]||'Unassigned':'Unassigned',
      duration:pf(dur),
      earlyStart:C.es?pd(r[C.es]):null,earlyFinish:C.ef?pd(r[C.ef]):null,
      actualStart:null,actualFinish:null,
      blStart:C.bls?pd(r[C.bls]):null,blFinish:C.blf?pd(r[C.blf]):null,
      totalFloat:isNaN(tf)?null:pf(tf),pct,status,
      type:dur===0?'Milestone':'Task',
      constraintType:'',constraintDate:null,hasConstraint:false,
      isCritical:tf!==null&&tf<=0,
      predecessors:C.pred?r[C.pred]?String(r[C.pred]).split(/[,;]+/).map(s=>s.trim()).filter(Boolean):[]:[], 
      successors:[],resources:[],_scopeTag:''
    };
  });
  const rels=[];
  activities.forEach(a=>{
    if(a.predecessors.length) a.predecessors.forEach(predId=>{rels.push({predId,succId:a.id,type:'FS',lag:0});});
  });
  return buildSchedule({
    projectName:wb.Props?.Title||'Excel Schedule',
    projectId:'',dataDate:new Date(),
    projStart:activities.reduce((m,a)=>a.earlyStart&&(!m||a.earlyStart<m)?a.earlyStart:m,null),
    projFinish:activities.reduce((m,a)=>a.earlyFinish&&(!m||a.earlyFinish>m)?a.earlyFinish:m,null),
    activities,rels,calRows:[]
  });
}

// ══════════════════════════════════════════
// BUILD SCHEDULE
// ══════════════════════════════════════════
function buildSchedule({projectName,projectId,dataDate,projStart,projFinish,activities,rels,calRows}){
  const byId={},byActId={};
  activities.forEach(a=>{byId[a.id]=a;byActId[a.actId]=a;});
  const predMap={},succMap={};
  rels.forEach(r=>{
    if(!predMap[r.succId]) predMap[r.succId]=[];
    predMap[r.succId].push(r.predId);
    if(!succMap[r.predId]) succMap[r.predId]=[];
    succMap[r.predId].push(r.succId);
  });
  activities.forEach(a=>{
    if(!a.predecessors.length) a.predecessors=(predMap[a.id]||[]).map(id=>byId[id]?.actId||id);
    a.successors=(succMap[a.id]||[]).map(id=>byId[id]?.actId||id);
    if(a.totalFloat!==null&&a.totalFloat<=0&&a.status!=='Completed') a.isCritical=true;
  });
  return{projectName,projectId,dataDate,projStart,projFinish,activities,relationships:rels,byId,byActId,predMap,succMap,calRows};
}

// ══════════════════════════════════════════
// BASELINE MERGE
// ══════════════════════════════════════════
function mergeBaseline(current,baseline){
  const blByActId={};
  baseline.activities.forEach(a=>{blByActId[a.actId]=a;});
  current.activities.forEach(a=>{
    const bl=blByActId[a.actId];
    if(bl){a.blStart=bl.earlyStart;a.blFinish=bl.earlyFinish;}
  });
  current.blProjectName=baseline.projectName;
  current.blProjectFinish=baseline.projFinish;
  current.blProjectStart=baseline.projStart;
  current.hasBaseline=true;
  return current;
}
