// SCOPE PARSER (PDF.js + Excel + CSV/TXT + Word-basic)
// ══════════════════════════════════════════
if(typeof pdfjsLib!=='undefined') pdfjsLib.GlobalWorkerOptions.workerSrc='https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

async function parseScopeDoc(file){
  const ext=file.name.split('.').pop().toLowerCase();
  let rawText='';
  if(ext==='pdf'){
    const arrayBuf=await file.arrayBuffer();
    const pdf=await pdfjsLib.getDocument({data:arrayBuf}).promise;
    const pages=[];
    for(let pg=1;pg<=Math.min(pdf.numPages,60);pg++){
      const page=await pdf.getPage(pg);
      const tc=await page.getTextContent();
      pages.push(tc.items.map(i=>i.str).join(' '));
    }
    rawText=pages.join('\n');
  } else if(ext==='xlsx'||ext==='xls'){
    const buf=await file.arrayBuffer();
    const wb=XLSX.read(buf,{type:'array'});
    wb.SheetNames.forEach(sn=>{
      const rows=XLSX.utils.sheet_to_json(wb.Sheets[sn],{raw:false,header:1});
      rows.forEach(row=>row.forEach(cell=>{if(cell&&String(cell).trim().length>3) rawText+=String(cell)+'\n';}));
    });
  } else if(ext==='csv'||ext==='txt'){
    rawText=await file.text();
  } else {
    // docx / doc — extract readable text from binary (basic)
    try{rawText=await file.text();}catch(e){rawText='';}
    // strip XML-like tags
    rawText=rawText.replace(/<[^>]+>/g,' ').replace(/\s{2,}/g,' ');
  }
  // Extract deliverable lines
  const planKw=['deliver','install','commission','procure','survey','design','fabricate','construct','test','inspect','complete','submit','approval','milestone','phase','stage','task','work','package','supply','erect','connect','hook','start','finish','mobilise','mobilize','handover','closeout','pre-commission','engineering','procurement','construction','piping','instrumentation','electrical','civil','structural','mechanical','painting','insulation','testing','welding','hydro','chemical','gas','oil','pipe','pump','valve','vessel','tank','compressor','generator','cable','conduit','foundation','excavation','backfill','grout','concrete'];
  const lines=rawText.split(/[\n\r]+/).map(l=>l.trim()).filter(l=>l.length>6&&l.length<350);
  const items=[],seen=new Set();
  lines.forEach(l=>{
    const lc=l.toLowerCase();
    const isJunk=/^[\d\s\.\-\,\:]+$/.test(l);
    if(isJunk||l.split(/\s+/).length<2) return;
    const key=l.substring(0,55).toLowerCase();
    if(seen.has(key)) return;
    seen.add(key);
    const score=planKw.filter(kw=>lc.includes(kw)).length;
    items.push({text:l,score});
  });
  items.sort((a,b)=>b.score-a.score);
  return{sourceFile:file.name,ext,items:items.slice(0,500)};
}

