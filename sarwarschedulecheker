function renderActs(acts){
  document.getElementById('acnt').textContent=`${acts.length} ${T('activities').toLowerCase()}`;
  document.getElementById('actTable').innerHTML=acts.slice(0,600).map(a=>{
    const dot=a.isCritical?'<span class="dc"></span>':a.totalFloat!==null&&a.totalFloat<=5&&a.totalFloat>=0?'<span class="dw"></span>':'';
    const fc=a.totalFloat!==null&&a.totalFloat<0?'color:var(--danger);font-weight:700':a.totalFloat===0?'color:var(--warning);font-weight:600':'';
    const sb=a.status==='Completed'?'bp2':a.status==='In progress'?'bw':'bna';
    const fdColor=a.finishDelay>0?'color:var(--danger)':a.finishDelay<0?'color:var(--success)':'';
    const scopeStyle=a._scopeTag==='✓'?'color:var(--success);font-weight:700':a._scopeTag==='⚠'?'color:var(--warning);font-weight:700':'color:var(--text3)';
    return`<tr>
      <td style="font-family:monospace;font-size:11px">${a.actId}</td>
      <td>${dot}${a.name.substring(0,45)}</td>
      <td><span class="badge ${a.type==='Milestone'?'bw':'bna'}">${a.type}</span></td>
      <td style="font-size:11px;color:var(--text3)">${a.wbs.substring(0,22)}</td>
      <td style="text-align:right">${a.duration>0?a.duration+'d':'—'}</td>
      <td>${fmt(a.earlyStart)}</td><td>${fmt(a.earlyFinish)}</td>
      <td style="${fdColor}">${a.blStart?fmt(a.blStart):'—'}</td>
      <td style="${fdColor}">${a.blFinish?fmt(a.blFinish):'—'}</td>
      <td style="text-align:right;${fc}">${a.totalFloat!==null?a.totalFloat+'d':'—'}</td>
      <td style="text-align:right">${a.pct>0?a.pct+'%':'—'}</td>
      <td><span class="badge ${sb}">${a.status}</span></td>
