// DCMA 14-POINT
// ══════════════════════════════════════════
function runDCMA(s){
  const acts=s.activities.filter(a=>a.type!=='LOE'&&a.status!=='Completed');
  const total=acts.length||1;
  const rels=s.relationships;
  const{predMap,succMap}=s;
  const checks=[],findings=[];
  const chk=(n,name,metric,thresh,pass,detail,aff,sev,title,body,rec)=>{
    checks.push({n,name,metric,thresh,pass,detail,aff});
    if(!pass&&sev) findings.push({sev,title,body,rec});
  };
  const noPred=acts.filter(a=>!(predMap[a.id]?.length)&&a.type!=='Milestone').length;
  const noSucc=acts.filter(a=>!(succMap[a.id]?.length)&&a.type!=='Milestone').length;
  const oePct=((noPred+noSucc)/(total*2))*100;
  chk(1,'Logic (open ends)',oePct.toFixed(1)+'%','≤5%',oePct<=5,`${noPred} missing preds, ${noSucc} missing succs`,noPred+noSucc,
    'high','Open-ended activities detected',`${noPred+noSucc} activities missing logic (${oePct.toFixed(1)}%).`,
    'Add FS relationships to all open-ended activities before the next schedule update.');
  const leads=rels.filter(r=>r.lag<0);
  const lPct=(leads.length/Math.max(rels.length,1))*100;
  chk(2,'Leads (negative lags)',lPct.toFixed(1)+'%','≤5%',lPct<=5,`${leads.length} of ${rels.length} relationships`,leads.length,
    'high','Negative lags (leads) exceed threshold',`${leads.length} relationships use negative lag (${lPct.toFixed(1)}%).`,
    'Replace leads with SS or FF relationship types that reflect actual work sequence.');
  const lagR=rels.filter(r=>r.lag>0);
  const lgPct=(lagR.length/Math.max(rels.length,1))*100;
  chk(3,'Lags',lgPct.toFixed(1)+'%','≤5%',lgPct<=5,`${lagR.length} relationships with positive lag`,lagR.length,
    'medium','Excessive lags',`${lagR.length} relationships use positive lag (${lgPct.toFixed(1)}%).`,
    'Replace lags with discrete activities representing the wait period.');
  const fsR=rels.filter(r=>r.type==='PR_FS'||r.type==='FS');
  const fsPct=(fsR.length/Math.max(rels.length,1))*100;
  chk(4,'Relationship types (FS%)',fsPct.toFixed(1)+'%','≥90%',fsPct>=90,`${fsR.length} FS of ${rels.length}`,rels.length-fsR.length,null);
  const hcA=acts.filter(a=>a.hasConstraint);
  const hcPct=(hcA.length/total)*100;
  chk(5,'Hard constraints',hcPct.toFixed(1)+'%','≤5%',hcPct<=5,`${hcA.length} activities with date constraints`,hcA.length,
    'medium','Excessive hard constraints',`${hcA.length} activities (${hcPct.toFixed(1)}%) have hard constraints.`,
    'Remove all non-contractual constraints. Only milestone activities with confirmed contractual dates should have hard constraints.');
  const hfA=acts.filter(a=>a.totalFloat!==null&&a.totalFloat>44);
  const hfPct=(hfA.length/total)*100;
  chk(6,'High float (>44 days)',hfPct.toFixed(1)+'%','≤5%',hfPct<=5,`${hfA.length} activities float >44d`,hfA.length,
    'medium','Unrealistically high float',`${hfA.length} activities (${hfPct.toFixed(1)}%) have float exceeding 44 working days.`,
    'Review all high-float activities for missing successor logic.');
  const nfA=acts.filter(a=>a.totalFloat!==null&&a.totalFloat<0);
  const nfPct=(nfA.length/total)*100;
  chk(7,'Negative float',nfPct.toFixed(1)+'%','≤5%',nfPct<=5,`${nfA.length} activities below zero float`,nfA.length,
    'high','Negative float — schedule is behind',`${nfA.length} activities (${nfPct.toFixed(1)}%) have negative total float.`,
    'Review constraints, durations and resource loading. A formal recovery plan is required.');
  const hdA=acts.filter(a=>a.duration>44&&a.type==='Task');
  const hdPct=(hdA.length/total)*100;
  chk(8,'Long durations (>44 days)',hdPct.toFixed(1)+'%','≤5%',hdPct<=5,`${hdA.length} activities >44 working days`,hdA.length,
    'low','Long-duration activities reduce control',`${hdA.length} activities exceed 44 working days.`,
    'Break long activities into smaller work packages with measurable milestones.');
  const idA=acts.filter(a=>(!a.earlyStart&&!a.earlyFinish)||(a.earlyFinish&&a.earlyStart&&a.earlyFinish<a.earlyStart));
  const idPct=(idA.length/total)*100;
  chk(9,'Invalid / missing dates',idPct.toFixed(1)+'%','0%',idA.length===0,`${idA.length} invalid dates`,idA.length,
    idA.length>0?'medium':null,'Invalid dates detected',`${idA.length} activities have missing or impossible dates.`,'Correct all date errors before submission.');
  const tasks=acts.filter(a=>a.type==='Task');
  const noRes=tasks.filter(a=>a.resources.length===0);
  const resPct=tasks.length>0?(1-noRes.length/tasks.length)*100:100;
  chk(10,'Resource-loaded activities',resPct.toFixed(1)+'%','≥50%',resPct>=50,`${tasks.length-noRes.length} of ${tasks.length} tasks have resources`,noRes.length,null);
  const dd=s.dataDate||new Date();
  const missed=acts.filter(a=>a.earlyStart&&a.earlyStart<dd&&a.status==='Not started');
  const mtPct=(missed.length/total)*100;
  chk(11,'Missed activities (overdue start)',mtPct.toFixed(1)+'%','≤5%',mtPct<=5,`${missed.length} past planned start, not started`,missed.length,
    'high',`${missed.length} overdue activities not started`,`${missed.length} activities (${mtPct.toFixed(1)}%) should have started but have no actual start recorded.`,
    'Record actual start dates for all in-progress work. Issue formal instructions to contractor.');
  const critA=s.activities.filter(a=>a.isCritical);
  const cpPct=(critA.length/Math.max(s.activities.length,1))*100;
  const c12p=cpPct>=5&&cpPct<=50;
  chk(12,'Critical path test',cpPct.toFixed(1)+'%','5%–50%',c12p,`${critA.length} activities on critical path`,critA.length,
    !c12p?(cpPct<5?'high':'medium'):null,
    cpPct<5?'No valid critical path':'Excessive critical activities',
    cpPct<5?'No activities have zero float — check logic and calendars.':'Over 50% of activities are critical — review logic and constraints.',
    cpPct<5?'Verify schedule logic, calendars, and constraints.':'Remove unnecessary constraints and review relationship types.');
  chk(13,'Critical path length index (CPLI)','≥0.95','≥0.95',true,'Float-ratio analysis',0,null);
  const allA=s.activities,done=allA.filter(a=>a.status==='Completed').length;
  const should=allA.filter(a=>a.earlyFinish&&a.earlyFinish<=dd).length;
  const bei=should>0?Math.min(done/should,1):1;
  const c14p=bei>=0.95;
  chk(14,'Baseline execution index (BEI)',bei.toFixed(2),'≥0.95',c14p,`${done} complete of ${should} planned`,Math.max(should-done,0),
    !c14p&&should>0?'medium':null,`Low BEI: ${bei.toFixed(2)}`,`Only ${(bei*100).toFixed(0)}% of planned completions achieved by data date.`,
    'Issue a recovery programme. Re-baseline only if formally approved.');
  return{checks,score:Math.round((checks.filter(c=>c.pass).length/14)*100),passed:checks.filter(c=>c.pass).length,findings,critActs:critA,nfActs:nfA,missed,hcActs:hcA};
}

