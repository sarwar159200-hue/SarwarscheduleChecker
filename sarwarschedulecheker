function runDelayAnalysis(s,dcma){
  const acts=s.activities;const dd=s.dataDate||new Date();
  const hasBaseline=s.hasBaseline||acts.some(a=>a.blStart||a.blFinish);
  let delayedActs=[],advancedActs=[],maxFinishDelay=0,critPathDelay=0;
  if(hasBaseline){
    acts.forEach(a=>{
      if(!a.blFinish||!a.earlyFinish){a.finishDelay=0;a.startDelay=0;a.isDelayedVsBL=false;return;}
      const fd=ddays(a.blFinish,a.earlyFinish)||0;
      const sd=a.blStart&&a.earlyStart?ddays(a.blStart,a.earlyStart)||0:0;
      a.finishDelay=fd;a.startDelay=sd;a.isDelayedVsBL=fd>0;
      if(fd>0){delayedActs.push(a);if(fd>maxFinishDelay)maxFinishDelay=fd;if(a.isCritical)critPathDelay=Math.max(critPathDelay,fd);}
      else if(fd<0) advancedActs.push(a);
    });
  } else {
    acts.forEach(a=>{
      a.finishDelay=a.totalFloat!==null&&a.totalFloat<0?Math.abs(a.totalFloat):0;
      a.startDelay=0;a.isDelayedVsBL=a.finishDelay>0;
    });
    delayedActs=acts.filter(a=>a.isDelayedVsBL);
  }
  const{nfActs,missed,hcActs}=dcma;
  let projectDelayDays=0;
  if(hasBaseline&&s.projFinish&&s.blProjectFinish) projectDelayDays=Math.max(0,ddays(s.blProjectFinish,s.projFinish)||0);
  else projectDelayDays=nfActs.length>0?Math.abs(Math.min(...nfActs.map(a=>a.totalFloat||0))):0;
  projectDelayDays=Math.max(projectDelayDays,critPathDelay);
  let rootCause='No delay detected — schedule is on track.';
  let responsible='Not determined';let causeCode='none';
  if(hasBaseline){
    if(projectDelayDays>0&&hcActs.length>(acts.length*0.05)){
      rootCause=`Baseline comparison confirms ${projectDelayDays} working days of delay. Hard constraints (${hcActs.length} activities) are a primary driver.`;
      responsible='Project Owner / Contractual Imposed Dates';causeCode='constraint';
    } else if(projectDelayDays>0&&missed.length>(acts.length*0.05)){
      rootCause=`Baseline comparison confirms ${projectDelayDays} working days of project delay. ${missed.length} activities are overdue vs baseline.`;
      responsible='Contractor — Execution Performance';causeCode='execution';
    } else if(projectDelayDays>0){
      rootCause=`Baseline comparison shows the project is ${projectDelayDays} working days behind the approved baseline. ${delayedActs.length} activities have slipped.`;
      responsible='Under investigation — Time Impact Analysis required';causeCode='general';
    } else if(delayedActs.length>0){
      rootCause=`${delayedActs.length} activities have slipped vs baseline, but overall project finish is not yet impacted. Recovery action recommended.`;
      responsible='Contractor — Execution Team';causeCode='partial';
    } else {
      rootCause='Baseline comparison shows all activities are on track or ahead of the approved baseline.';
      responsible='N/A — on schedule';causeCode='none';
    }
  } else {
    if(nfActs.length>0) rootCause=`${nfActs.length} critical path activities have negative float. Upload an approved baseline for definitive analysis.`;
    else if(missed.length>0) rootCause=`${missed.length} activities are overdue. Upload an approved baseline for accurate delay quantification.`;
    responsible='Under investigation (no baseline loaded)';
  }
  const delayStarts=[...delayedActs,...nfActs].map(a=>a.blStart||a.earlyStart).filter(Boolean);
  const delayFinishes=[...delayedActs,...nfActs].map(a=>a.earlyFinish||a.blFinish).filter(Boolean);
  const firstDelay=delayStarts.length?new Date(Math.min(...delayStarts.map(d=>d.getTime()))):null;
  const lastDelay=delayFinishes.length?new Date(Math.max(...delayFinishes.map(d=>d.getTime()))):null;
  const wbsCounts={};
  [...delayedActs,...nfActs].forEach(a=>{wbsCounts[a.wbs]=(wbsCounts[a.wbs]||0)+1;});
  const topWbs=Object.entries(wbsCounts).sort((a,b)=>b[1]-a[1]).slice(0,3);
  const wh=[
    {q:T('whatDel'),icon:'❓',bg:'#e0f0ff',color:'#1558c7',
      answer:projectDelayDays>0?`The project is currently <strong>${projectDelayDays} working days</strong> behind the ${hasBaseline?'approved baseline':'planned schedule'}. ${delayedActs.length} activities have slipped.`
        :delayedActs.length>0?`${delayedActs.length} activities have slipped vs baseline. Project finish not yet impacted.`
        :'No delay detected.',
      detail:delayedActs.length>0?`Most delayed: ${delayedActs.slice(0,3).map(a=>a.actId+' ('+a.finishDelay+'d)').join('; ')}`:''},
    {q:T('whenDel'),icon:'📅',bg:'#fef9c3',color:'#854d0e',
      answer:firstDelay?`Earliest indicator: <strong>${fmt(firstDelay)}</strong>.`:'No delay start identified.',
      detail:`Data date: ${fmt(dd)}. Plan finish: ${fmt(s.projFinish)}. ${hasBaseline&&s.blProjectFinish?'BL finish: '+fmt(s.blProjectFinish)+'.':''}`},
    {q:T('whereDel'),icon:'📍',bg:'#dcfce7',color:'#15803d',
      answer:topWbs.length?`Delay concentrated in: ${topWbs.map(([w,c])=>`<strong>${w}</strong> (${c})`).join(', ')}.`:'No area identified.',
      detail:`Total affected: ${[...new Set([...delayedActs,...nfActs])].length}. Critical impacted: ${dcma.critActs.filter(a=>a.isDelayedVsBL||a.totalFloat<0).length}.`},
    {q:T('whoResp'),icon:'👤',bg:'#fce7f3',color:'#9d174d',
      answer:responsible,
      detail:causeCode==='constraint'?'Hard constraints are overriding schedule logic. If owner-imposed, delay may be excusable/compensable. TIA required.'
        :causeCode==='execution'?'Contractor behind plan. Verify excusable events before assessing entitlement.'
        :causeCode==='none'?'No responsible party — on schedule.':'TIA or Windows Analysis required.'},
    {q:T('whyDel'),icon:'🔍',bg:'#ede9fe',color:'#5b21b6',
      answer:rootCause,
      detail:(()=>{const r=[];if(!hasBaseline)r.push('⚠ No baseline');if(nfActs.length)r.push(nfActs.length+' neg float');if(delayedActs.length&&hasBaseline)r.push(delayedActs.length+' slipped');if(missed.length)r.push(missed.length+' overdue');if(hcActs.length)r.push(hcActs.length+' constraints');return r.join(' · ');})()},
    {q:T('howMuch'),icon:'📏',bg:'#ffedd5',color:'#9a3412',
      answer:projectDelayDays>0?`<strong>${projectDelayDays} working days</strong> (≈${Math.round(projectDelayDays*1.4)} calendar days).${hasBaseline?' BL finish: '+fmt(s.blProjectFinish)+'. Current: '+fmt(s.projFinish)+'.':''}`
        :delayedActs.length>0?`No confirmed project delay. Risk: up to ${Math.round(maxFinishDelay)} days if not recovered.`
        :'No measurable delay — on or ahead of schedule.',
      detail:hasBaseline&&s.blProjectFinish&&s.projFinish?`BL: ${fmt(s.blProjectFinish)}. Current: ${fmt(s.projFinish)}. Diff: ${ddays(s.blProjectFinish,s.projFinish)||0}d.`:''}
  ];
  const delayTypes=[
    {cls:'dt-crit',title:T('critDelay'),body:projectDelayDays>0?`${projectDelayDays} working days of confirmed critical delay.`:'No critical delay to project completion confirmed at this time.'},
    {cls:'dt-exc',title:T('excDelay'),body:causeCode==='constraint'?`Owner-imposed constraints may qualify as excusable. TIA required.`:'No clearly excusable events identified from schedule data.'},
    {cls:'dt-comp',title:T('compDelay'),body:causeCode==='constraint'?`If owner-imposed constraints are proven, contractor may be entitled to time extension and cost. Formal delay claim analysis recommended.`:'Compensability cannot be determined from schedule data alone.'},
    {cls:'dt-conc',title:T('concDelay'),body:delayedActs.length>0&&missed.length>0&&hcActs.length>0?`Multiple concurrent delay events detected. Concurrent delay assessment required.`:'No concurrent delay pattern identified.'}
  ];
  const recs=[];
  if(projectDelayDays>0){
    recs.push(`Fast-track: Overlap critical path activities. Target recovery of ${Math.ceil(projectDelayDays*0.4)} days through SS/FF relationships.`);
    recs.push(`Crash: Add resources to the ${Math.min(5,dcma.critActs.length)} longest critical activities. Estimated recovery: ${Math.ceil(projectDelayDays*0.35)} days at ~15–25% cost premium.`);
    recs.push(`Submit formal recovery programme within 14 days showing how the ${projectDelayDays}-day delay will be recovered.`);
  }
  if(missed.length>0) recs.push(`Mobilise immediately: Issue written instruction to start all ${missed.length} overdue activities. Request weekly updates.`);
  if(hcActs.length>0) recs.push(`Remove constraints: Review all ${hcActs.length} hard constraints. Removing non-contractual constraints may immediately recover float at no cost.`);
  if(!hasBaseline) recs.push(`Upload approved baseline: Without a baseline, delay analysis is indicative only. Upload the approved baseline (Rev A) for definitive assessment.`);
  if(SC&&SC.missing.length>0) recs.push(`Address scope gaps: ${SC.missing.length} scope items have no corresponding schedule activity. Add missing activities to the schedule.`);
  recs.push(`Issue a formal Time Impact Analysis (TIA) documenting all delay events, quantifying critical impact, and establishing contractual entitlement.`);
  const allDelayed=[...new Set([...delayedActs,...nfActs,...missed])].sort((a,b)=>(b.finishDelay||0)-(a.finishDelay||0)).slice(0,150);
  return{wh,delayTypes,recs,projectDelayDays,rootCause,responsible,impacted:allDelayed,firstDelay,lastDelay,hasBaseline,delayedActs,advancedActs,maxFinishDelay,critPathDelay};
}
</script>
<script>
// ══════════════════════════════════════════
// RENDER FUNCTIONS
// ══════════════════════════════════════════
function renderAll(sched,dcma,delay){
  S=sched;D=dcma;DA=delay;allActs=[...sched.activities];
  const acts=sched.activities;
  document.getElementById('pname').textContent=sched.projectName;
  const td=ddays(sched.projStart,sched.projFinish);
  document.getElementById('pmeta').innerHTML=
    `${T('step1').replace('Step 1 — Upload current schedule','Format')}: <b>${sched._format||'XER'}</b> &nbsp;·&nbsp; Data date: <b>${fmt(sched.dataDate)}</b> &nbsp;·&nbsp; <b>${fmt(sched.projStart)}</b> → <b>${fmt(sched.projFinish)}</b>`+
    (td?` (${td}d)`:'')+` &nbsp;·&nbsp; ${T('activities')}: <b>${acts.length}</b> &nbsp;·&nbsp; ${T('relationships')}: <b>${sched.relationships.length}</b>`+
    (sched.hasBaseline?` &nbsp;·&nbsp; <span style="color:var(--success)">✓ ${T('blLoaded')} ${sched.blProjectName}</span>`:'')+
    (SC?` &nbsp;·&nbsp; <span style="color:var(--purple)">🔭 ${SC.items.length} scope items</span>`:'');
  const arc=document.getElementById('sarc');
  arc.style.strokeDashoffset=314-(dcma.score/100)*314;
  arc.style.stroke=dcma.score>=75?'#15803d':dcma.score>=50?'#b45309':'#b91c1c';
  document.getElementById('snum').textContent=dcma.score;
  const v=document.getElementById('sverd');
  if(dcma.score>=75){v.textContent=T('good');v.className='verd vg';}
  else if(dcma.score>=50){v.textContent=T('acceptable');v.className='verd vw';}
  else{v.textContent=T('needsImprovement');v.className='verd vb';}
  const crit=acts.filter(a=>a.isCritical),comp=acts.filter(a=>a.status==='Completed');
  const inprog=acts.filter(a=>a.status==='In progress'),nf=acts.filter(a=>a.totalFloat!==null&&a.totalFloat<0);
  document.getElementById('kgrid').innerHTML=[
    {v:acts.length,l:T('activities'),s:`${acts.filter(a=>a.type==='Milestone').length} milestones`},
    {v:sched.relationships.length,l:T('relationships'),s:''},
    {v:crit.length,l:T('critical'),s:`${((crit.length/Math.max(acts.length,1))*100).toFixed(0)}%`,c:crit.length?'var(--danger)':''},
    {v:comp.length,l:T('completed'),s:`${((comp.length/Math.max(acts.length,1))*100).toFixed(0)}%`,c:'var(--success)'},
    {v:inprog.length,l:T('inProgress'),s:''},
    {v:nf.length,l:T('negFloat'),s:'',c:nf.length?'var(--danger)':''},
    {v:delay.projectDelayDays>0?delay.projectDelayDays+'d':T('noDelay'),l:T('projDelay'),s:delay.hasBaseline?T('vsBaseline'):T('floatBased'),c:delay.projectDelayDays>0?'var(--danger)':'var(--success)'},
    {v:dcma.passed+'/14',l:T('dcmaChecks'),s:`${dcma.score}%`},
    {v:SC?SC.missing.length:T('notApplicable'),l:T('scopeGaps'),s:SC?SC.sourceFile.substring(0,12)+'…':T('noScopeLoaded'),c:SC&&SC.missing.length?'var(--danger)':SC?'var(--success)':'var(--text3)'}
  ].map(k=>`<div class="kpi"><div class="kv" style="${k.c?'color:'+k.c:''}">${k.v}</div><div class="kl">${k.l}</div>${k.s?'<div class="ks">'+k.s+'</div>':''}</div>`).join('');
  renderDCMA(dcma.checks);
  renderDelay(sched,dcma,delay);
  renderBaseline(sched,delay);
  renderScope();
  renderActs(allActs);
  renderCritical(sched,crit);
  renderFindings(dcma.findings);
  renderReport(sched,dcma,delay);
  setTimeout(()=>renderCharts(sched),80);
  const dashBl=document.getElementById('dashBlBtn');
  if(dashBl) dashBl.style.display=sched.hasBaseline?'inline-flex':'none';
}

function renderDCMA(checks){
  document.getElementById('dcmaGrid').innerHTML=checks.map(c=>`
    <div class="di">
      <div class="dn">${c.n}</div>
      <div><div class="dname">${c.name}</div><div class="ddet">${c.detail} · Threshold: ${c.thresh}</div></div>
      <div class="dmet" style="color:${c.pass?'var(--success)':'var(--danger)'}">${c.metric}</div>
      <span class="badge ${c.pass?'bp2':'bf'}">${c.pass?'PASS':'FAIL'}</span>
    </div>`).join('');
}

function renderDelay(sched,dcma,delay){
  document.getElementById('delayBanner').innerHTML=delay.projectDelayDays>0
    ?`<div class="bb-no">⚠ <b>${delay.projectDelayDays} ${T('delayBannerWarn')} ${delay.hasBaseline?T('vsBaseline'):T('floatBased')}.</b> ${delay.rootCause}</div>`
    :delay.impacted.length>0?`<div class="bb-no">⚠ <b>${delay.impacted.length} activities have slipped vs baseline</b> but project finish not yet impacted.</div>`
    :`<div class="bb-yes">✓ ${T('delayBannerNone')} ${delay.hasBaseline?'All activities on track vs baseline.':'Upload baseline for definitive assessment.'}</div>`;
  document.getElementById('dkrow').innerHTML=[
    {v:delay.projectDelayDays>0?delay.projectDelayDays+'d':T('noDelay'),l:T('projDelay'),c:delay.projectDelayDays>0?'var(--danger)':'var(--success)'},
    {v:fmt(delay.firstDelay),l:'First delay date'},
    {v:fmt(delay.lastDelay),l:'Impact end'},
    {v:delay.delayedActs.length,l:'Activities vs BL',c:delay.delayedActs.length?'var(--warning)':''},
    {v:delay.hasBaseline?'✓ Loaded':'✗ None',l:T('blLoaded').replace(':',''),c:delay.hasBaseline?'var(--success)':'var(--warning)'},
    {v:delay.responsible,l:T('whoResp')}
  ].map(k=>`<div class="dkpi"><div class="dkv" style="${k.c?'color:'+k.c:''}">${k.v}</div><div class="dkl">${k.l}</div></div>`).join('');
  document.getElementById('whgrid').innerHTML=delay.wh.map(w=>`
    <div class="whcard">
      <div class="whlbl"><div class="whico" style="background:${w.bg};color:${w.color}">${w.icon}</div>${w.q}</div>
      <div class="whbody">${w.answer}</div>
      ${w.detail?'<div class="whdet">'+w.detail+'</div>':''}
    </div>`).join('');
  document.getElementById('dtgrid').innerHTML=delay.delayTypes.map(t=>`
    <div class="dtcard ${t.cls}"><div class="dtt">${t.title}</div><div class="dtb">${t.body}</div></div>`).join('');
  document.getElementById('delayTable').innerHTML=delay.impacted.length
    ?delay.impacted.map(a=>{
        const fc=a.finishDelay>0?'color:var(--danger);font-weight:700':a.finishDelay<0?'color:var(--success)':'';
        const sc=a.startDelay>0?'color:var(--warning);font-weight:600':'';
        const imp=a.finishDelay>0?a.finishDelay+'d late':a.totalFloat!==null&&a.totalFloat<0?Math.abs(a.totalFloat)+'d neg':'Overdue';
        const bimpc=a.finishDelay>5?'bf':a.finishDelay>0?'bw':'bna';
        const rec=a.finishDelay>5?'Immediate recovery':a.finishDelay>0?'Accelerate':a.totalFloat!==null&&a.totalFloat<0?'Recovery plan':'Mobilise';
        return`<tr>
          <td style="font-family:monospace;font-size:11px">${a.actId}</td>
          <td>${a.name.substring(0,45)}</td>
          <td>${fmt(a.blStart)}</td><td>${fmt(a.blFinish)}</td>
          <td>${fmt(a.earlyStart)}</td><td>${fmt(a.earlyFinish)}</td>
          <td style="${sc}">${a.startDelay!==undefined&&a.startDelay!==0?(a.startDelay>0?'+':'')+a.startDelay+'d':'—'}</td>
          <td style="${fc}">${a.finishDelay!==undefined&&a.finishDelay!==0?(a.finishDelay>0?'+':'')+a.finishDelay+'d':'—'}</td>
          <td style="text-align:right;${a.totalFloat!==null&&a.totalFloat<0?'color:var(--danger);font-weight:700':''}">${a.totalFloat!==null?a.totalFloat+'d':'—'}</td>
          <td><span class="badge ${bimpc}">${imp}</span></td>
          <td style="font-size:11px;color:var(--accent)">${rec}</td>
        </tr>`;
      }).join('')
    :'<tr><td colspan="11" class="empty">No delay-impacted activities found</td></tr>';
  document.getElementById('recbox').innerHTML=`<div class="rboxt">${T('recoveryRecs')}</div>`+
    delay.recs.map((r,i)=>`<div class="ritem"><b>Option ${i+1}:</b> ${r}</div>`).join('');
}

function renderBaseline(sched,delay){
  if(!delay.hasBaseline){
    document.getElementById('blBanner').innerHTML=`<div class="bb-no">⚠ <b>${T('blNotLoaded')}</b> Upload an approved baseline XER, XML, or XLSX file (Step 2 on the upload screen) for definitive delay analysis.</div>`;
    document.getElementById('blContent').innerHTML=`<div class="empty">Load an approved baseline to see activity-by-activity comparison here.</div>`;
    return;
  }
  document.getElementById('blBanner').innerHTML=`<div class="bb-yes">✓ <b>${T('blLoaded')} ${sched.blProjectName}</b> · ${T('blStart')}: ${fmt(sched.blProjectStart)} · ${T('blFinish')}: ${fmt(sched.blProjectFinish)} · ${delay.delayedActs.length} activities slipped · ${delay.advancedActs.length} ahead</div>`;
  const delayed=delay.delayedActs.length,advanced=delay.advancedActs.length;
  const acts=sched.activities.filter(a=>a.blFinish&&a.earlyFinish);
  const onTime=acts.length-delayed-advanced;
  document.getElementById('blContent').innerHTML=`
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:.65rem;margin-bottom:1rem">
      ${[{v:acts.length,l:'Compared'},{v:delayed,l:'Delayed vs BL',c:delayed?'var(--danger)':''},{v:advanced,l:'Ahead of BL',c:advanced?'var(--success)':''},{v:onTime,l:'On track',c:'var(--success)'},{v:fmt(sched.blProjectStart),l:T('blStart')},{v:fmt(sched.blProjectFinish),l:T('blFinish')}].map(k=>`<div class="dkpi"><div class="dkv" style="${k.c?'color:'+k.c:''}">${k.v}</div><div class="dkl">${k.l}</div></div>`).join('')}
    </div>
    <div class="stitle">Activity-by-activity baseline comparison</div>
    <div class="tw"><table><thead><tr>
      <th>${T('activities2')}</th><th>${T('actName')}</th><th>${T('blStart')}</th><th>${T('blFinish')}</th>
      <th>${T('curStart')}</th><th>${T('curFinish')}</th><th>${T('startVar')}</th><th>${T('finishVar')}</th><th>Critical</th><th>${T('statusCol')}</th>
    </tr></thead><tbody>
      ${sched.activities.filter(a=>a.blStart||a.blFinish).slice(0,400).map(a=>{
        const sd=a.startDelay||0,fd=a.finishDelay||0;
        const fc=fd>0?'color:var(--danger);font-weight:700':fd<0?'color:var(--success)':'';
        const sc2=sd>0?'color:var(--warning);font-weight:600':'';
        return`<tr>
          <td style="font-family:monospace;font-size:11px">${a.actId}</td>
          <td>${a.name.substring(0,45)}</td>
          <td>${fmt(a.blStart)}</td><td>${fmt(a.blFinish)}</td>
          <td>${fmt(a.earlyStart)}</td><td>${fmt(a.earlyFinish)}</td>
          <td style="${sc2}">${sd!==0?(sd>0?'+':'')+sd+'d':'—'}</td>
          <td style="${fc}">${fd!==0?(fd>0?'+':'')+fd+'d':'—'}</td>
          <td>${a.isCritical?'<span class="dc"></span>Yes':'No'}</td>
          <td><span class="badge ${a.status==='Completed'?'bp2':a.status==='In progress'?'bw':'bna'}">${a.status}</span></td>
        </tr>`;
      }).join('')}
    </tbody></table></div>`;
}

function renderScope(){
  const el=document.getElementById('scopeContent');
  if(!SC){
    el.innerHTML=`
      <div class="bb-scope">🔭 <b>${T('scopeNoDoc')}</b> Upload a scope document (Step 3) to run gap analysis between your scope and schedule.</div>
      <div style="background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:1.25rem;box-shadow:var(--sh)">
        <div class="stitle">${T('scopeHowTitle')}</div>
        <ol style="margin:0;padding-inline-start:1.3rem;font-size:13px;color:var(--text2);line-height:2">
          ${T('scopeHowSteps').map(s=>`<li>${s}</li>`).join('')}
        </ol>
        <div style="margin-top:1rem;display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:.65rem">
          ${[['📄','PDF','Scope of Work, ITT docs'],['📊','Excel','WPR, Deliverable lists'],['📝','Word/DOCX','Scope documents, specs'],['📋','CSV / TXT','Simple deliverable lists']].map(([ico,t,d])=>`<div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:.75rem;text-align:center"><div style="font-size:22px">${ico}</div><div style="font-size:12px;font-weight:700;color:var(--purple);margin:.25rem 0">${t}</div><div style="font-size:11px;color:var(--text3)">${d}</div></div>`).join('')}
        </div>
      </div>`;
    return;
  }
  const covPct=SC.items.length?Math.round((SC.matched.length/SC.items.length)*100):0;
  el.innerHTML=`
    ${SC.missing.length>0
      ?`<div class="bb-no">❌ <b>${SC.missing.length} ${T('scopeMissingN')}</b> — these may represent missing schedule activities.</div>`
      :`<div class="bb-yes">✓ All ${SC.matched.length} scope items matched to schedule activities.</div>`}
    <div class="scope-stats">
      ${[{v:SC.items.length,l:T('scopeItems')},{v:SC.matched.length,l:T('scopeMatchedN'),c:'var(--success)'},{v:SC.missing.length,l:T('scopeMissingN'),c:SC.missing.length?'var(--danger)':''},{v:SC.orphans.length,l:T('scopeUncovN'),c:SC.orphans.length?'var(--warning)':''},{v:covPct+'%',l:T('scopeCovRate'),c:covPct>=80?'var(--success)':covPct>=50?'var(--warning)':'var(--danger)'},{v:SC.sourceFile,l:T('scopeSource')}].map(k=>`<div class="sstat"><div class="sstat-v" style="${k.c?'color:'+k.c:''}">${k.v}</div><div class="sstat-l">${k.l}</div></div>`).join('')}
    </div>
    ${SC.missing.length?`
    <div class="stitle" style="color:var(--danger)">❌ ${T('scopeMissing')} (${SC.missing.length})</div>
    <div class="tw" style="margin-bottom:1rem"><table><thead><tr><th>#</th><th>${T('scopeItemCol')}</th><th>${T('confidence')}</th></tr></thead><tbody>
    ${SC.missing.slice(0,150).map((m,i)=>`<tr><td>${i+1}</td><td>${m.text.substring(0,80)}</td><td style="color:var(--danger);font-weight:700">${m.conf}% (below 15% threshold)</td></tr>`).join('')}
    </tbody></table></div>`:''}
    ${SC.orphans.length?`
    <div class="stitle" style="color:var(--warning)">⚠ ${T('scopeOrphans')} (${SC.orphans.length})</div>
    <div class="tw" style="margin-bottom:1rem"><table><thead><tr><th>${T('activities2')}</th><th>${T('actName')}</th><th>${T('wbsCol')}</th><th>${T('statusCol')}</th><th>${T('floatCol')}</th></tr></thead><tbody>
