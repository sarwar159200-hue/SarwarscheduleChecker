// SCOPE vs SCHEDULE MATCHING
// ══════════════════════════════════════════
function runScopeMatch(scopeRaw,sched){
  const stopwords=new Set(['the','a','an','and','or','of','to','in','is','are','for','with','that','this','be','as','at','by','from','on','it','its','per','each','shall','will','all','any']);
  const tokenise=s=>s.toLowerCase().replace(/[^a-z0-9\s]/g,' ').split(/\s+/).filter(w=>w.length>2&&!stopwords.has(w));
  const actTokens=sched.activities.map(a=>({a,toks:new Set(tokenise(a.name+' '+(a.wbs||'')))}));
  const matched=[],missing=[];
  scopeRaw.items.forEach(item=>{
    const itoks=new Set(tokenise(item.text));
    if(itoks.size===0) return;
    let best=null,bestScore=0;
    actTokens.forEach(({a,toks})=>{
      let inter=0;itoks.forEach(t=>{if(toks.has(t)) inter++;});
      const score=Math.round((inter/Math.max(itoks.size,toks.size,1))*100);
      if(score>bestScore){bestScore=score;best=a;}
    });
    if(best&&bestScore>=15){
      matched.push({scopeText:item.text,actId:best.actId,actName:best.name,conf:bestScore});
      if(!best._scopeTag) best._scopeTag='✓';
    } else {
      missing.push({text:item.text,conf:bestScore});
    }
  });
  const covIds=new Set(matched.map(m=>m.actId));
  const orphans=sched.activities.filter(a=>a.type!=='Milestone'&&!covIds.has(a.actId));
  orphans.forEach(a=>{if(!a._scopeTag)a._scopeTag='⚠';});
  return{sourceFile:scopeRaw.sourceFile,items:scopeRaw.items,matched,missing,orphans};
}
