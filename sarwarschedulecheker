<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sarwar SchedulePro AI v5 — P6 Schedule Check</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#0b1f3a;--navy2:#132d52;--navy3:#1a3a68;
  --accent:#1d6feb;--accent2:#1558c7;
  --gold:#c9922a;--gold2:#f0b84a;
  --success:#15803d;--warning:#b45309;--danger:#b91c1c;
  --purple:#7c3aed;--purple2:#6d28d9;
  --sbg:#dcfce7;--wbg:#fef9c3;--dbg:#fee2e2;--pbg:#ede9fe;
  --border:#dee2e8;--surface:#f4f6fa;--white:#fff;
  --text:#0d1b2e;--text2:#2d3f56;--text3:#60748a;
  --r:8px;--sh:0 1px 4px rgba(0,0,0,.09);--shm:0 4px 16px rgba(0,0,0,.12);
}
body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--surface);color:var(--text);min-height:100vh}
.hdr{background:var(--navy);padding:0 1.75rem;display:flex;align-items:center;height:58px;position:sticky;top:0;z-index:200;box-shadow:0 2px 12px rgba(0,0,0,.35)}
.hicon{width:36px;height:36px;background:linear-gradient(135deg,var(--accent),var(--gold));border-radius:8px;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:17px;color:#fff;flex-shrink:0}
.hmain{font-size:15px;font-weight:700;color:#fff;letter-spacing:-.01em}
.hsub{font-size:10px;color:#7fa4cc;letter-spacing:.05em;text-transform:uppercase}
.hsp{flex:1}
.hdev{text-align:right;font-size:11px;color:#4d7aa0;line-height:1.5}
.hdev strong{color:#89b8df;display:block;font-size:12px}
.upwrap{padding:3rem 2rem;max-width:960px;margin:0 auto}
.uphero{text-align:center;margin-bottom:2rem}
.uphero h1{font-size:28px;font-weight:800;color:var(--navy);letter-spacing:-.02em;margin-bottom:.5rem}
.uphero p{font-size:14px;color:var(--text3);max-width:600px;margin:0 auto}
.upload-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem}
.ucard{border:2px dashed #b0bec8;border-radius:14px;padding:1.75rem 1.25rem;text-align:center;background:#fff;cursor:pointer;transition:all .2s;box-shadow:var(--sh)}
.ucard:hover,.ucard.drag{border-color:var(--accent);background:#eef5ff}
.ucard-icon{font-size:36px;display:block;margin-bottom:.6rem}
.ucard-title{font-size:14px;font-weight:700;color:var(--navy);margin-bottom:.25rem}
.ucard-sub{font-size:12px;color:var(--text3);margin-bottom:.85rem}
.ubtn{display:inline-flex;align-items:center;gap:.4rem;background:var(--accent);color:#fff;border:none;padding:.5rem 1.25rem;border-radius:var(--r);font-size:13px;font-weight:600;cursor:pointer;transition:background .15s}
.ubtn:hover{background:var(--accent2)}
.ubtn-purple{background:var(--purple)}.ubtn-purple:hover{background:var(--purple2)}
.baseline-zone{border:2px dashed #f0b84a;border-radius:12px;padding:1.25rem;text-align:center;background:#fffbeb;cursor:pointer;transition:all .2s}
.baseline-zone:hover{background:#fef3c7;border-color:var(--gold)}
.baseline-zone.loaded{border-color:var(--success);background:#f0fdf4}
.scope-zone{border:2px dashed #a78bfa;border-radius:12px;padding:1.25rem;text-align:center;background:#faf5ff;cursor:pointer;transition:all .2s;margin-top:.75rem}
.scope-zone:hover{background:#f3e8ff;border-color:var(--purple)}
.scope-zone.loaded{border-color:var(--purple);background:#ede9fe}
.btag{display:inline-block;font-size:11px;font-weight:700;padding:.2rem .6rem;border-radius:10px;margin-bottom:.4rem}
.btag-bl{background:var(--wbg);color:var(--warning)}
.btag-sc{background:var(--pbg);color:var(--purple)}
.pills{display:flex;flex-wrap:wrap;gap:.5rem;justify-content:center;margin-top:1.5rem}
.pill{background:#fff;border:1px solid var(--border);border-radius:20px;padding:.3rem .85rem;font-size:12px;font-weight:500;color:var(--text2)}
.loading{display:none;flex-direction:column;align-items:center;gap:1.1rem;padding:4rem;text-align:center}
.spin{width:44px;height:44px;border:3px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:sp .75s linear infinite}
@keyframes sp{to{transform:rotate(360deg)}}
.lstep{font-size:12.5px;color:var(--text3);padding:.2rem 0;display:flex;align-items:center;gap:.5rem}
.lstep.done{color:var(--success)}.lstep.active{color:var(--accent);font-weight:600}
.dash{display:none;padding:1.5rem 2rem 3rem;max-width:1440px;margin:0 auto}
.dtop{display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:1.25rem;flex-wrap:wrap}
.pname{font-size:21px;font-weight:800;color:var(--navy);letter-spacing:-.02em}
.pmeta{font-size:12px;color:var(--text3);margin-top:.3rem;line-height:1.7}
.dbtns{display:flex;gap:.5rem;flex-wrap:wrap}
.btn{padding:.48rem 1.1rem;border-radius:var(--r);font-size:13px;font-weight:600;cursor:pointer;border:none;transition:all .15s}
.bg{background:#fff;color:var(--text2);border:1.5px solid var(--border)}.bg:hover{background:var(--surface)}
.bp{background:var(--accent);color:#fff}.bp:hover{background:var(--accent2)}
.bgo{background:var(--gold);color:#fff}.bgo:hover{background:#a07218}
.bpu{background:var(--purple);color:#fff}.bpu:hover{background:var(--purple2)}
.srow{display:grid;grid-template-columns:210px 1fr;gap:1.1rem;margin-bottom:1.1rem}
.scard{background:#fff;border:1px solid var(--border);border-radius:14px;padding:1.25rem;text-align:center;box-shadow:var(--sh);display:flex;flex-direction:column;align-items:center;justify-content:center}
.sring{position:relative;width:120px;height:120px;margin-bottom:.75rem}
.sring svg{transform:rotate(-90deg)}
.snum{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:28px;font-weight:800;color:var(--navy)}
.slbl{font-size:11.5px;color:var(--text3);font-weight:600;letter-spacing:.03em;text-transform:uppercase}
.verd{margin-top:.5rem;font-size:12px;font-weight:700;padding:.25rem .8rem;border-radius:20px}
.vg{background:var(--sbg);color:var(--success)}.vw{background:var(--wbg);color:var(--warning)}.vb{background:var(--dbg);color:var(--danger)}
.kgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(118px,1fr));gap:.65rem}
.kpi{background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:.85rem 1rem;box-shadow:var(--sh)}
.kv{font-size:22px;font-weight:800;color:var(--navy);line-height:1}
.kl{font-size:10px;font-weight:600;color:var(--text3);margin-top:.3rem;text-transform:uppercase;letter-spacing:.04em}
.ks{font-size:11px;color:var(--text3);margin-top:.1rem}
.tabs{display:flex;border-bottom:2px solid var(--border);margin-bottom:1.25rem;overflow-x:auto}
.tab{padding:.6rem 1.2rem;font-size:13px;font-weight:600;color:var(--text3);cursor:pointer;border-bottom:2.5px solid transparent;margin-bottom:-2px;white-space:nowrap;transition:color .15s}
.tab:hover{color:var(--navy)}.tab.active{color:var(--accent);border-bottom-color:var(--accent)}
.tab-scope.active{color:var(--purple);border-bottom-color:var(--purple)}
.tp{display:none}.tp.active{display:block}
.sec-dl{display:flex;gap:.4rem;margin-bottom:.85rem;flex-wrap:wrap;align-items:center;background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:.55rem .75rem;box-shadow:var(--sh)}
.sec-dl-lbl{font-size:11px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.04em;flex:1;min-width:80px}
.sdl{display:inline-flex;align-items:center;gap:.3rem;padding:.3rem .75rem;border-radius:5px;font-size:12px;font-weight:600;cursor:pointer;border:1.5px solid;transition:all .15s}
.sdl-pdf{color:#b91c1c;border-color:#b91c1c}.sdl-pdf:hover{background:#fef2f2}
.sdl-xl{color:#15803d;border-color:#15803d}.sdl-xl:hover{background:#f0fdf4}
.sdl-wd{color:#1558c7;border-color:#1558c7}.sdl-wd:hover{background:#eef5ff}
.dcma-grid{display:grid;gap:.55rem}
.di{background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:.85rem 1.1rem;display:grid;grid-template-columns:32px 1fr auto auto;align-items:center;gap:.85rem;box-shadow:var(--sh)}
.dn{width:28px;height:28px;border-radius:6px;background:var(--navy);color:#fff;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0}
.dname{font-size:13px;font-weight:600;color:var(--text)}
.ddet{font-size:11px;color:var(--text3);margin-top:.12rem}
.dmet{font-size:13px;font-weight:700;text-align:right;min-width:55px}
.badge{display:inline-flex;align-items:center;font-size:11px;font-weight:700;padding:.2rem .6rem;border-radius:20px}
.bp2{background:var(--sbg);color:var(--success)}.bf{background:var(--dbg);color:var(--danger)}
.bw{background:var(--wbg);color:var(--warning)}.bi{background:#e0f0ff;color:#1558c7}.bna{background:#f1f5f9;color:#64748b}
.bpu2{background:var(--pbg);color:var(--purple)}
.tw{overflow-x:auto;border-radius:var(--r);border:1px solid var(--border);background:#fff;box-shadow:var(--sh)}
table{width:100%;border-collapse:collapse;font-size:12px}
th{background:var(--navy);color:#fff;padding:.55rem .9rem;text-align:left;font-weight:600;font-size:11px;white-space:nowrap}
td{padding:.44rem .9rem;border-bottom:1px solid var(--border);color:var(--text2);white-space:nowrap}
tr:last-child td{border-bottom:none}
tr:nth-child(even) td{background:#f8fafc}
tr:hover td{background:#eef5ff}
.dc{display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--danger);margin-right:.3rem;vertical-align:middle}
.dw{display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--warning);margin-right:.3rem;vertical-align:middle}
.fr{display:flex;gap:.6rem;margin-bottom:.85rem;flex-wrap:wrap;align-items:center}
.fr input,.fr select{padding:.38rem .7rem;border:1.5px solid var(--border);border-radius:var(--r);font-size:12.5px;background:#fff;color:var(--text);outline:none}
.fr input:focus,.fr select:focus{border-color:var(--accent)}
.cgrid{display:grid;grid-template-columns:1fr 1fr;gap:1.1rem}
.ccard{background:#fff;border:1px solid var(--border);border-radius:12px;padding:1.1rem;box-shadow:var(--sh)}
.ctitle{font-size:13px;font-weight:700;color:var(--navy);margin-bottom:.75rem}
.cwrap{position:relative;height:220px}
.flist{display:grid;gap:.65rem}
.fc{background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:.9rem 1.1rem;border-left:4px solid;box-shadow:var(--sh)}
.fh{border-left-color:var(--danger)}.fm{border-left-color:var(--warning)}.fl{border-left-color:var(--success)}
.ft{font-size:13px;font-weight:700;color:var(--text);margin:.3rem 0 .2rem}
.fb{font-size:12.5px;color:var(--text3);line-height:1.6}
.frec{font-size:12px;color:var(--navy);background:#eef5ff;border-radius:5px;padding:.45rem .7rem;margin-top:.5rem;line-height:1.55}
.daly-hero{background:#fff;border:1px solid var(--border);border-radius:14px;padding:1.25rem;box-shadow:var(--sh);margin-bottom:1.1rem}
.dkrow{display:grid;grid-template-columns:repeat(auto-fit,minmax(155px,1fr));gap:.75rem;margin-bottom:1.1rem}
.dkpi{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:.9rem;text-align:center}
.dkv{font-size:19px;font-weight:800;color:var(--navy);margin-bottom:.2rem}
.dkl{font-size:10.5px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.04em}
.whgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:.9rem;margin-bottom:1.1rem}
.whcard{background:#fff;border:1px solid var(--border);border-radius:12px;padding:1.1rem;box-shadow:var(--sh)}
.whlbl{display:flex;align-items:center;gap:.55rem;font-size:11px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:.55rem}
.whico{width:26px;height:26px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0}
.whbody{font-size:13px;color:var(--text);line-height:1.65}
.whdet{font-size:12px;color:var(--text3);margin-top:.35rem;line-height:1.55}
.dtgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(185px,1fr));gap:.65rem;margin-bottom:1.1rem}
.dtcard{border-radius:var(--r);padding:.9rem 1rem;border:1px solid}
.dt-exc{background:#e0f0ff;border-color:#93c5fd}.dt-comp{background:var(--wbg);border-color:#fbbf24}
.dt-conc{background:#fce7f3;border-color:#f9a8d4}.dt-crit{background:var(--dbg);border-color:#fca5a5}
.dtt{font-size:12px;font-weight:700;color:var(--navy);margin-bottom:.3rem}
.dtb{font-size:12px;color:var(--text2);line-height:1.5}
.rbox{background:linear-gradient(135deg,var(--navy),var(--navy3));border-radius:12px;padding:1.1rem 1.35rem;color:#fff;margin-top:1rem}
.rboxt{font-size:13px;font-weight:700;margin-bottom:.6rem;color:var(--gold2)}
.ritem{font-size:12.5px;line-height:1.55;padding:.45rem .7rem;background:rgba(255,255,255,.07);border-radius:5px;border-left:3px solid var(--gold2);margin-bottom:.4rem}
.bb-yes{background:#dcfce7;border:1px solid #86efac;border-radius:var(--r);padding:.65rem 1rem;font-size:12.5px;color:var(--success);margin-bottom:.85rem;font-weight:600}
.bb-no{background:var(--wbg);border:1px solid #fbbf24;border-radius:var(--r);padding:.65rem 1rem;font-size:12.5px;color:var(--warning);margin-bottom:.85rem}
.bb-scope{background:var(--pbg);border:1px solid #a78bfa;border-radius:var(--r);padding:.65rem 1rem;font-size:12.5px;color:var(--purple);margin-bottom:.85rem;font-weight:600}
.bldiff-head{display:grid;grid-template-columns:140px 1fr 90px 90px 90px 90px 100px;gap:.5rem;background:var(--navy);color:#fff;font-size:11px;font-weight:600;padding:.5rem .75rem;border-radius:var(--r) var(--r) 0 0}
.bldiff-row{display:grid;grid-template-columns:140px 1fr 90px 90px 90px 90px 100px;gap:.5rem;font-size:12px;padding:.45rem .75rem;border-bottom:1px solid var(--border);background:#fff;align-items:center}
.bldiff-row:nth-child(even){background:#f8fafc}
.repwrap{background:#fff;border:1px solid var(--border);border-radius:14px;padding:2rem;box-shadow:var(--sh);max-width:960px}
.rcov{border-bottom:3px solid var(--navy);padding-bottom:1.5rem;margin-bottom:1.5rem}
.rlogbar{display:flex;align-items:center;gap:.85rem;margin-bottom:.85rem}
.rlogbox{background:var(--navy);color:#fff;padding:.4rem .9rem;border-radius:5px;font-size:13.5px;font-weight:800}
.rtitle{font-size:22px;font-weight:800;color:var(--navy);letter-spacing:-.02em}
.rsub{font-size:13px;color:var(--text3);margin-top:.2rem}
.rmeta{display:grid;grid-template-columns:1fr 1fr;gap:.35rem .65rem;margin-top:.9rem;background:var(--surface);border-radius:var(--r);padding:.8rem .95rem;font-size:12.5px}
.rrow{display:flex;gap:.5rem}.rl{color:var(--text3);min-width:105px;flex-shrink:0}.rv{color:var(--text);font-weight:600}
.rsec{margin-bottom:1.35rem}
.rst{font-size:14px;font-weight:800;color:var(--navy);border-bottom:1.5px solid var(--border);padding-bottom:.35rem;margin-bottom:.75rem}
.rb{font-size:13px;color:var(--text2);line-height:1.75}
.sigbox{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1.5rem;margin-top:1rem}
.sig{border-top:1px solid var(--border);padding-top:.65rem;text-align:center;font-size:12px;color:var(--text3)}
.sign{font-size:13px;font-weight:700;color:var(--text);margin-bottom:.2rem}
.stitle{font-size:14px;font-weight:700;color:var(--navy);margin-bottom:.75rem}
.ibox{background:#eef5ff;border:1px solid #93c5fd;border-radius:var(--r);padding:.75rem 1rem;font-size:12.5px;color:#1d3e70;margin-bottom:.9rem;line-height:1.6}
.empty{text-align:center;padding:2rem;color:var(--text3);font-size:13px}
/* SCOPE STATS */
.scope-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:.65rem;margin-bottom:1rem}
.sstat{background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:.85rem 1rem;box-shadow:var(--sh);text-align:center}
.sstat-v{font-size:22px;font-weight:800;line-height:1}
.sstat-l{font-size:10px;font-weight:600;color:var(--text3);margin-top:.3rem;text-transform:uppercase;letter-spacing:.04em}
/* EXPORT MODAL */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(11,31,58,.55);z-index:500;align-items:center;justify-content:center}
.modal-overlay.open{display:flex}
.modal{background:#fff;border-radius:16px;padding:2rem;width:680px;max-width:95vw;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.25)}
.modal-title{font-size:18px;font-weight:800;color:var(--navy);margin-bottom:.25rem}
.modal-sub{font-size:12.5px;color:var(--text3);margin-bottom:1.25rem}
.fmt-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:.65rem;margin-bottom:1.35rem}
.fmt-card{border:2px solid var(--border);border-radius:10px;padding:.9rem .65rem;text-align:center;cursor:pointer;transition:all .15s}
.fmt-card:hover{border-color:var(--accent);background:#f0f7ff}
.fmt-card.active{border-color:var(--accent);background:#eef5ff}
.fmt-icon{font-size:28px;display:block;margin-bottom:.35rem}
.fmt-label{font-size:12px;font-weight:700;color:var(--navy)}
.fmt-ext{font-size:11px;color:var(--text3)}
.chk-grid{display:grid;grid-template-columns:1fr 1fr;gap:.4rem .9rem;margin-bottom:1.25rem}
.chk-item{display:flex;align-items:center;gap:.5rem;font-size:13px;color:var(--text2);cursor:pointer}
.chk-item input{width:15px;height:15px;cursor:pointer;accent-color:var(--accent)}
.modal-footer{display:flex;gap:.65rem;justify-content:flex-end;padding-top:1rem;border-top:1px solid var(--border)}
@media(max-width:768px){
  .srow{grid-template-columns:1fr}.cgrid{grid-template-columns:1fr}
  .dash{padding:1rem}.whgrid{grid-template-columns:1fr}
  .upload-grid{grid-template-columns:1fr}
  .di{grid-template-columns:32px 1fr auto}.dmet{display:none}
  .fmt-grid{grid-template-columns:repeat(2,1fr)}
  .chk-grid{grid-template-columns:1fr}
}
@media print{.hdr,.dbtns,.tabs,.fr,.sec-dl,.modal-overlay{display:none!important}.tp{display:block!important}}
</style>
</head>
<body>
<!-- HEADER -->
<header class="hdr">
  <div style="display:flex;align-items:center;gap:.75rem">
    <div class="hicon">S</div>
    <div style="display:flex;flex-direction:column;line-height:1.25">
      <span class="hmain">Sarwar SchedulePro AI</span>
      <span class="hsub" id="appSub">v5 · P6 · MS Project · Scope Gap · Multi-Format Export</span>
    </div>
  </div>
  <div class="hsp"></div>
  <div class="hdev"><strong>Sarwar</strong>Planning &amp; Project Controls</div>
</header>

<!-- UPLOAD SECTION -->
<div class="upwrap" id="uploadSection">
  <div class="uphero">
    <h1 id="heroTitle">Multi-Format Schedule Intelligence</h1>
    <p id="heroSub">Upload your schedule, optionally your approved baseline, and optionally your scope document — then get DCMA health check, baseline delay analysis, and scope gap analysis with multi-format export.</p>
  </div>

  <!-- STEP 1 -->
  <div id="step1lbl" style="font-size:13px;font-weight:700;color:var(--navy);margin-bottom:.6rem">Step 1 — Upload current schedule</div>
  <div class="upload-grid">
    <div class="ucard" id="dz-xer" onclick="document.getElementById('fi-xer').click()">
      <span class="ucard-icon">🏗️</span>
      <div class="ucard-title">Primavera P6</div>
      <div class="ucard-sub">.XER file</div>
      <button class="ubtn" onclick="event.stopPropagation();document.getElementById('fi-xer').click()">Choose XER</button>
    </div>
    <div class="ucard" id="dz-xml" onclick="document.getElementById('fi-xml').click()">
      <span class="ucard-icon">📊</span>
      <div class="ucard-title">MS Project / P6 XML</div>
      <div class="ucard-sub">.XML (MSPDI or P6 XML)</div>
      <button class="ubtn" onclick="event.stopPropagation();document.getElementById('fi-xml').click()">Choose XML</button>
    </div>
    <div class="ucard" id="dz-xlsx" onclick="document.getElementById('fi-xlsx').click()">
      <span class="ucard-icon">📋</span>
      <div class="ucard-title">Excel</div>
      <div class="ucard-sub">.XLSX activity list</div>
      <button class="ubtn" onclick="event.stopPropagation();document.getElementById('fi-xlsx').click()">Choose Excel</button>
