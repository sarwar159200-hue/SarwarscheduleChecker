      <td style="font-size:11px;${scopeStyle}">${a._scopeTag||'—'}</td>
    </tr>`;
  }).join('')||'<tr><td colspan="14" class="empty">No activities</td></tr>';
}

function filterActs(){
  const s=document.getElementById('asrch').value.toLowerCase();
  const st=document.getElementById('astat').value;
  const ft=document.getElementById('afilt').value;
  const f=allActs.filter(a=>{
    if(s&&!a.name.toLowerCase().includes(s)&&!a.actId.toLowerCase().includes(s)) return false;
    if(st&&a.status!==st) return false;
    if(ft==='critical'&&!a.isCritical) return false;
    if(ft==='near'&&(a.totalFloat===null||a.totalFloat>5||a.totalFloat<0)) return false;
    if(ft==='neg'&&(a.totalFloat===null||a.totalFloat>=0)) return false;
    if(ft==='milestone'&&a.type!=='Milestone') return false;
    if(ft==='delay'&&!a.isDelayedVsBL) return false;
    if(ft==='scope-miss'&&a._scopeTag!=='⚠') return false;
    return true;
  });
  renderActs(f);
}

function renderCritical(sched,crit){
  const acts=sched.activities;
  const avg=acts.filter(a=>a.totalFloat!==null).reduce((s,a)=>s+a.totalFloat,0)/Math.max(acts.filter(a=>a.totalFloat!==null).length,1);
  document.getElementById('cpsumm').innerHTML=[
    ['Critical activities',crit.length],
    ['Near-critical (1–5d float)',acts.filter(a=>a.totalFloat!==null&&a.totalFloat>0&&a.totalFloat<=5).length],
    ['Negative float',acts.filter(a=>a.totalFloat!==null&&a.totalFloat<0).length],
    ['Average total float',avg.toFixed(1)+'d'],
    ['Project start',fmt(sched.projStart)],['Project finish',fmt(sched.projFinish)],
    ['BL finish',DA.hasBaseline?fmt(sched.blProjectFinish):T('noBaseline')]
  ].map(([l,v])=>`<div style="display:flex;justify-content:space-between;border-bottom:1px solid var(--border);padding:.28rem 0"><span style="color:var(--text3)">${l}</span><strong>${v}</strong></div>`).join('');
  document.getElementById('critTable').innerHTML=crit.slice(0,200).map(a=>
    `<tr>
      <td style="font-family:monospace;font-size:11px"><span class="dc"></span>${a.actId}</td>
      <td>${a.name.substring(0,55)}</td>
      <td style="text-align:right">${a.duration}d</td>
      <td>${fmt(a.earlyStart)}</td><td>${fmt(a.earlyFinish)}</td>
