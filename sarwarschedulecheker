function exportCSV(){
  const r=[['Activity ID','Name','Type','WBS','Duration(d)','Early Start','Early Finish','BL Start','BL Finish','Total Float(d)','% Complete','Status','Start Var(d)','Finish Var(d)','Critical','Constraint','Predecessors','Scope Tag']];
  S.activities.forEach(a=>r.push([a.actId,`"${a.name.replace(/"/g,'""')}"`,a.type,`"${a.wbs}"`,a.duration,fmt(a.earlyStart),fmt(a.earlyFinish),fmt(a.blStart||null),fmt(a.blFinish||null),a.totalFloat!=null?a.totalFloat:'',a.pct,a.status,a.startDelay||0,a.finishDelay||0,a.isCritical?'Yes':'No',a.constraintType||'',`"${a.predecessors.join(',')}"`,a._scopeTag||'']));
  const csv=r.map(row=>row.join(',')).join('\n');
  const blob=new Blob(['\ufeff'+csv],{type:'text/csv;charset=utf-8'});
  const url=URL.createObjectURL(blob);const a=document.createElement('a');
  a.href=url;a.download=`Sarwar_SchedulePro_${S.projectName.replace(/[^a-z0-9]/gi,'_')}_activities.csv`;
  a.click();URL.revokeObjectURL(url);
}

// ══════════════════════════════════════════
// MODAL & EXPORT DISPATCH
// ══════════════════════════════════════════
let selectedFmt='pdf';
function openModal(){document.getElementById('exportModal').classList.add('open');}
function closeModal(){document.getElementById('exportModal').classList.remove('open');}
document.getElementById('exportModal').addEventListener('click',e=>{if(e.target===e.currentTarget)closeModal();});
function selectFmt(f){
  selectedFmt=f;
  ['pdf','xl','wd','csv'].forEach(x=>document.getElementById('fmt'+x.charAt(0).toUpperCase()+x.slice(1)).classList.toggle('active',x===f));
}
function collectOpts(){
  return{summary:document.getElementById('chk-summary').checked,dcma:document.getElementById('chk-dcma').checked,
    delay:document.getElementById('chk-delay').checked,baseline:document.getElementById('chk-baseline').checked,
    critical:document.getElementById('chk-critical').checked,findings:document.getElementById('chk-findings').checked,
    activities:document.getElementById('chk-activities').checked,scope:document.getElementById('chk-scope').checked,
    sig:document.getElementById('chk-sig').checked};
}
function runExport(){
  closeModal();const o=collectOpts();
  if(selectedFmt==='pdf') exportPDF(o);
  else if(selectedFmt==='xl') exportExcel(o);
  else if(selectedFmt==='wd') exportWord(o);
  else exportCSV();
}
// Per-section download
function secExport(sec,fmt){
  const all={summary:true,dcma:true,delay:true,baseline:true,critical:true,findings:true,activities:true,scope:true,sig:true};
  const secMap={dcma:{dcma:true,sig:true},delay:{delay:true,sig:true},baseline:{baseline:true,sig:true},scope:{scope:true,sig:true},activities:{activities:true,sig:true},critical:{critical:true,sig:true},charts:{},findings:{findings:true,sig:true},report:all};
  const o={...{summary:false,dcma:false,delay:false,baseline:false,critical:false,findings:false,activities:false,scope:false,sig:false},...(secMap[sec]||all)};
  if(fmt==='pdf') exportPDF(o);
  else if(fmt==='xl') exportExcel(o);
  else if(fmt==='wd') exportWord(o);
  else exportCSV();
}
</script>
<script>
// ══════════════════════════════════════════
// FILE HANDLING & MAIN FLOW
// ══════════════════════════════════════════
function setStep(n){for(let i=1;i<=6;i++){const e=document.getElementById('ls'+i);if(e)e.className=i<n?'lstep done':i===n?'lstep active':'lstep';}}

function processFile(file){
  const ext=file.name.split('.').pop().toLowerCase();
  return new Promise((resolve,reject)=>{
    if(ext==='xlsx'||ext==='xls'){
      const fr=new FileReader();
      fr.onload=e=>{try{const s=parseExcel(new Uint8Array(e.target.result));s._format='Excel';resolve(s);}catch(err){reject(err);}};
      fr.onerror=()=>reject(new Error('Could not read file'));
      fr.readAsArrayBuffer(file);
    } else {
      const fr=new FileReader();
      fr.onload=e=>{try{
        const text=e.target.result;let s;
        if(ext==='xer'){s=parseXER(text);s._format='P6 XER';}
        else if(ext==='xml'){s=parseXML(text);s._format=text.includes('APIBusinessObjects')||text.includes('<WBS>')?'P6 XML':'MS Project XML';}
        else throw new Error('Unsupported file type: .'+ext);
        resolve(s);
      }catch(err){reject(err);}};
      fr.onerror=()=>reject(new Error('Could not read file'));
      fr.readAsText(file,'UTF-8');
    }
  });
}

let pendingFile=null,baselineSched=null,scopeRaw=null;

async function loadAndAnalyse(){
  try{
    setStep(2);
    let sched=await processFile(pendingFile);
    setStep(3);
    if(baselineSched) sched=mergeBaseline(sched,baselineSched);
    setStep(4);
    const dcma=runDCMA(sched);
    setStep(5);
    const delay=runDelayAnalysis(sched,dcma);
    setStep(6);
    // Scope matching
    if(scopeRaw){SC=runScopeMatch(scopeRaw,sched);}
    else SC=null;
    await new Promise(r=>setTimeout(r,200));
    renderAll(sched,dcma,delay);
    document.getElementById('loadingSection').style.display='none';
    document.getElementById('dashboard').style.display='block';
  }catch(err){
    alert('Error: '+err.message+'\n\nPlease check this is a valid P6 XER, MSPDI XML, P6 XML, or Excel file.');
    resetApp();
  }
}

function handleScheduleFile(file){
  if(!file) return;
  pendingFile=file;
  document.getElementById('uploadSection').style.display='none';
  document.getElementById('loadingSection').style.display='flex';
  document.getElementById('lmsg').textContent='Processing '+file.name+'…';
  setStep(1);
  setTimeout(loadAndAnalyse,100);
}

// Wire up schedule file inputs
['xer','xml','xlsx'].forEach(fmt_=>{
  const inp=document.getElementById('fi-'+fmt_);
  inp.addEventListener('change',e=>{if(e.target.files[0]) handleScheduleFile(e.target.files[0]);});
});
// Drag and drop
['dz-xer','dz-xml','dz-xlsx'].forEach(id=>{
  const el=document.getElementById(id);
  el.addEventListener('dragover',e=>{e.preventDefault();el.classList.add('drag');});
  el.addEventListener('dragleave',()=>el.classList.remove('drag'));
  el.addEventListener('drop',e=>{e.preventDefault();el.classList.remove('drag');const f=e.dataTransfer.files[0];if(f) handleScheduleFile(f);});
});

// ── BASELINE ──
function blZoneClick(e){if(!baselineSched) document.getElementById('fi-bl').click();}
function setBaselineLoaded(name){
  document.getElementById('bl-label').textContent='✓ Baseline loaded: '+name;
  document.getElementById('bl-label').style.color='var(--success)';
  document.getElementById('bl-tag').textContent='✓ BASELINE LOADED';
  document.getElementById('bl-sub').textContent='Baseline will be compared against the current schedule. Use the buttons below to change or remove it.';
  document.getElementById('bl-actions').style.display='flex';
  document.getElementById('dz-bl').classList.add('loaded');
  document.getElementById('dz-bl').style.cursor='default';
}
function removeBaseline(){
  baselineSched=null;
  document.getElementById('bl-label').textContent=T('blDrop');
  document.getElementById('bl-label').style.color='';
  document.getElementById('bl-tag').textContent='BASELINE';
  document.getElementById('bl-sub').textContent=T('blDropSub');
  document.getElementById('bl-actions').style.display='none';
  document.getElementById('dz-bl').classList.remove('loaded');
  document.getElementById('dz-bl').style.cursor='pointer';
  document.getElementById('fi-bl').value='';
}
function removeBLFromDash(){
  removeBaseline();
  document.getElementById('dashBlBtn').style.display='none';
  if(pendingFile){
    document.getElementById('loadingSection').style.display='flex';
    document.getElementById('dashboard').style.display='none';
    document.getElementById('lmsg').textContent='Re-analysing without baseline…';
    setStep(1);setTimeout(loadAndAnalyse,100);
  }
}
document.getElementById('fi-bl').addEventListener('change',async e=>{
  const f=e.target.files[0];if(!f) return;
  try{baselineSched=await processFile(f);setBaselineLoaded(f.name);}
  catch(err){alert('Baseline error: '+err.message);}
});
const blEl=document.getElementById('dz-bl');
blEl.addEventListener('dragover',e=>{e.preventDefault();if(!baselineSched) blEl.style.borderColor='var(--success)';});
blEl.addEventListener('dragleave',()=>blEl.style.borderColor='');
blEl.addEventListener('drop',async e=>{
  e.preventDefault();blEl.style.borderColor='';
  const f=e.dataTransfer.files[0];
  if(f){try{baselineSched=await processFile(f);setBaselineLoaded(f.name);}catch(err){alert('Baseline error: '+err.message);}}
});

// ── SCOPE ──
function scZoneClick(e){if(!scopeRaw) document.getElementById('fi-sc').click();}
function setScopeLoaded(name,count){
  document.getElementById('sc-label').textContent=`✓ Scope loaded: ${name} — ${count} deliverable items extracted`;
  document.getElementById('sc-label').style.color='var(--success)';
  document.getElementById('sc-tag').textContent='✓ SCOPE LOADED';
  document.getElementById('sc-sub').textContent='Scope document is ready. It will be compared against the schedule activities on upload.';
  document.getElementById('sc-actions').style.display='flex';
  document.getElementById('dz-sc').classList.add('loaded');
  document.getElementById('dz-sc').style.cursor='default';
}
function removeScope(){
  scopeRaw=null;SC=null;
  document.getElementById('sc-label').textContent=T('scDrop');
  document.getElementById('sc-label').style.color='';
  document.getElementById('sc-tag').textContent='SCOPE DOC';
  document.getElementById('sc-sub').textContent=T('scDropSub');
  document.getElementById('sc-actions').style.display='none';
  document.getElementById('dz-sc').classList.remove('loaded');
  document.getElementById('dz-sc').style.cursor='pointer';
  document.getElementById('fi-sc').value='';
}
document.getElementById('fi-sc').addEventListener('change',async e=>{
  const f=e.target.files[0];if(!f) return;
  try{
    document.getElementById('sc-label').textContent='⏳ Parsing scope document — please wait…';
    document.getElementById('sc-label').style.color='var(--accent)';
    scopeRaw=await parseScopeDoc(f);
    setScopeLoaded(f.name,scopeRaw.items.length);
  }catch(err){alert('Scope parse error: '+err.message);}
});
const scEl=document.getElementById('dz-sc');
scEl.addEventListener('dragover',e=>{e.preventDefault();if(!scopeRaw) scEl.style.borderColor='var(--purple)';});
scEl.addEventListener('dragleave',()=>scEl.style.borderColor='');
scEl.addEventListener('drop',async e=>{
  e.preventDefault();scEl.style.borderColor='';
  const f=e.dataTransfer.files[0];
  if(f){
    try{
      document.getElementById('sc-label').textContent='⏳ Parsing scope document…';
      document.getElementById('sc-label').style.color='var(--accent)';
      scopeRaw=await parseScopeDoc(f);setScopeLoaded(f.name,scopeRaw.items.length);
    }catch(err){alert('Scope parse error: '+err.message);}
  }
});

// ── TAB SWITCHING ──
function showTab(name,el){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.tp').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('tab-'+name).classList.add('active');
  if(name==='charts'&&S) setTimeout(()=>renderCharts(S),50);
}

// ── RESET ──
function resetApp(){
  document.getElementById('uploadSection').style.display='block';
  document.getElementById('loadingSection').style.display='none';
  document.getElementById('dashboard').style.display='none';
  ['fi-xer','fi-xml','fi-xlsx'].forEach(id=>document.getElementById(id).value='');
  pendingFile=null;
  // Keep baseline and scope so user can load new schedule against same
}
</script>
</body>
</html>
