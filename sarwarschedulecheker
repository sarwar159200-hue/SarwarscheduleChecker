    return;
  }
  const ord={high:0,medium:1,low:2};
  document.getElementById('findList').innerHTML=[...findings].sort((a,b)=>ord[a.sev]-ord[b.sev]).map((f,i)=>`
    <div class="fc ${f.sev==='high'?'fh':f.sev==='medium'?'fm':'fl'}">
      <div style="display:flex;gap:.45rem;align-items:center">
        <span class="badge ${f.sev==='high'?'bf':f.sev==='medium'?'bw':'bp2'}">${f.sev.toUpperCase()}</span>
        <span style="font-size:11px;color:var(--text3)">Finding ${i+1}</span>
      </div>
      <div class="ft">${f.title}</div>
      <div class="fb">${f.body}</div>
      ${f.rec?'<div class="frec">💡 <b>Recommendation:</b> '+f.rec+'</div>':''}
