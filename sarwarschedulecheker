    <div class="stitle">✓ ${T('scopeMatched')} (${SC.matched.length})</div>
    <div class="tw"><table><thead><tr><th>#</th><th>${T('scopeItemCol')}</th><th>${T('activities2')}</th><th>${T('matchedActCol')}</th><th>${T('confidence')}</th></tr></thead><tbody>
