<script>
// ══════════════════════════════════════════
// UTILITIES
// ══════════════════════════════════════════
const pd=s=>{if(!s||s===''||s==='null') return null;const d=new Date(s.replace(' ','T'));return isNaN(d)?null:d;};
const fmt=d=>d?d.toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'}):'—';
const ddays=(a,b)=>(a&&b)?Math.round((b-a)/86400000):null;
const pf=n=>n!==null&&n!==undefined?Math.round(n*10)/10:null;
let S=null,BL=null,D=null,DA=null,SC=null,allActs=[];
let charts={};

// ══════════════════════════════════════════
// XER PARSER
// ══════════════════════════════════════════
function parseXER(text){
  const lines=text.split(/\r?\n/),tables={};
  let tbl=null,hdrs=[];
  for(const line of lines){
    if(!line.trim()) continue;
    if(line.startsWith('%T\t')){tbl=line.slice(3).trim();tables[tbl]=[];hdrs=[];}
    else if(line.startsWith('%F\t')) hdrs=line.slice(3).split('\t').map(h=>h.trim());
    else if(line.startsWith('%R\t')&&tbl&&hdrs.length){
      const v=line.slice(3).split('\t'),r={};
      hdrs.forEach((h,i)=>{r[h]=(v[i]||'').trim();});
      tables[tbl].push(r);
    }
  }
  return normaliseXER(tables);
}
function normaliseXER(tables){
  const proj=(tables['PROJECT']||tables['project']||[])[0]||{};
  const taskRows=tables['TASK']||tables['task']||[];
  const relRows=tables['TASKPRED']||tables['taskpred']||[];
  const wbsRows=tables['PROJWBS']||tables['projwbs']||[];
  const wbsMap={};
  wbsRows.forEach(w=>{wbsMap[w.wbs_id]=w.wbs_name||w.wbs_short_name||w.wbs_id;});
  const activities=taskRows.map(t=>{
    const dur=parseFloat(t.target_drtn_hr_cnt||t.remain_drtn_hr_cnt||'0')/8;
    const tf=parseFloat(t.total_float_hr_cnt||'9999')/8;
    const pct=parseFloat(t.phys_complete_pct||t.act_pct_of_work||'0');
    const sc=t.status_code||'TK_NotStart';
    let status='Not started';
    if(sc==='TK_Complete'||sc==='TK_Done') status='Completed';
    else if(sc==='TK_Active'||sc==='TK_InProg') status='In progress';
    const isMile=(t.task_type==='TT_Mile'||t.task_type==='TT_FinMile'||t.task_type==='TT_StartMile'||dur===0);
    const hasCon=t.cstr_type&&t.cstr_type!==''&&t.cstr_type!=='CS_NLT'&&t.cstr_type!=='CS_ALAP';
    const tfVal=isNaN(parseFloat(t.total_float_hr_cnt))?null:pf(tf);
    return{
      id:t.task_id,actId:t.task_code||t.task_id,name:t.task_name||'(unnamed)',
      wbsId:t.wbs_id,wbs:wbsMap[t.wbs_id]||'Unassigned',
      duration:pf(dur),
      earlyStart:pd(t.early_start_date||t.target_start_date),
      earlyFinish:pd(t.early_end_date||t.target_end_date),
      actualStart:pd(t.act_start_date),actualFinish:pd(t.act_end_date),
      blStart:null,blFinish:null,
      totalFloat:tfVal,pct,status,
      type:isMile?'Milestone':(t.task_type==='TT_LOE'?'LOE':'Task'),
      constraintType:t.cstr_type||'',constraintDate:pd(t.cstr_date),
      hasConstraint:hasCon,isCritical:false,
      predecessors:[],successors:[],resources:[],_scopeTag:''
    };
  });
  const rels=relRows.map(r=>({
    predId:r.pred_task_id,succId:r.task_id,
    type:r.pred_type||'PR_FS',lag:parseFloat(r.lag_hr_cnt||'0')/8
  }));
  return buildSchedule({
    projectName:proj.proj_short_name||proj.proj_id||'Unnamed Project',
    projectId:proj.proj_id||'',
    dataDate:pd(proj.last_recalc_date||proj.plan_start_date),
    projStart:pd(proj.plan_start_date||proj.scd_start_date),
    projFinish:pd(proj.scd_end_date||proj.plan_end_date||proj.anticip_end_date),
    activities,rels,calRows:[]
  });
}

// ══════════════════════════════════════════
// XML PARSERS
// ══════════════════════════════════════════
function parseXML(text){
  const parser=new DOMParser();
  const doc=parser.parseFromString(text,'application/xml');
  if(doc.querySelector('parsererror')) throw new Error('Invalid XML file');
  const isP6XML=!!doc.querySelector('APIBusinessObjects')||!!doc.querySelector('Project>WBS');
  if(isP6XML) return parseP6XML(doc);
  return parseMSPDI(doc);
}
function parseMSPDI(doc){
  const g=s=>doc.querySelector(s)?.textContent||'';
  const all=s=>[...doc.querySelectorAll(s)];
  const projName=g('Project>Name')||g('Project>Title')||'MS Project Schedule';
  const projStart=pd(g('Project>StartDate')||g('Project>Start'));
  const projFinish=pd(g('Project>FinishDate')||g('Project>Finish'));
  const dataDate=pd(g('Project>StatusDate')||g('Project>CurrentDate'))||new Date();
  const resMap={};
  all('Resource').forEach(r=>{const id=r.querySelector('UID')?.textContent;const nm=r.querySelector('Name')?.textContent;if(id&&nm)resMap[id]=nm;});
  const wbs={};
  all('WBS').forEach(w=>{const id=w.querySelector('UID')?.textContent;const nm=w.querySelector('Name')?.textContent;if(id)wbs[id]=nm||id;});
  const taskMap={};
  const activities=[];
  all('Task').forEach(t=>{
    const id=t.querySelector('UID')?.textContent;
    const name=t.querySelector('Name')?.textContent||'(unnamed)';
    if(!id||id==='0'||name==='Project Summary') return;
    const durRaw=t.querySelector('Duration')?.textContent||'PT0H0M0S';
    const durMatch=durRaw.match(/PT?(\d+)H/);
    const dur=durMatch?parseFloat(durMatch[1])/8:0;
    const pct=parseFloat(t.querySelector('PercentComplete')?.textContent||'0');
    const tf=parseFloat(t.querySelector('TotalSlack')?.textContent||'0')/480;
    const isMile=t.querySelector('Milestone')?.textContent==='1'||dur===0;
    const cs=t.querySelector('ConstraintType')?.textContent||'0';
    const hasCon=cs!=='0'&&cs!=='';
    let status='Not started';
    const sc2=t.querySelector('PercentComplete')?.textContent;
    if(sc2==='100') status='Completed';
    else if(sc2&&parseFloat(sc2)>0) status='In progress';
    const act={
      id,actId:t.querySelector('ID')?.textContent||id,name,
      wbs:wbs[t.querySelector('WBS')?.textContent||'']||'Unassigned',
      duration:pf(dur),
      earlyStart:pd(t.querySelector('EarlyStart')?.textContent||t.querySelector('Start')?.textContent),
      earlyFinish:pd(t.querySelector('EarlyFinish')?.textContent||t.querySelector('Finish')?.textContent),
      actualStart:pd(t.querySelector('ActualStart')?.textContent),
      actualFinish:pd(t.querySelector('ActualFinish')?.textContent),
      blStart:pd(t.querySelector('BaselineStart')?.textContent),
      blFinish:pd(t.querySelector('BaselineFinish')?.textContent),
      totalFloat:isNaN(tf)?null:pf(tf),pct,status,
      type:isMile?'Milestone':'Task',
      constraintType:cs!=='0'?'CS_'+cs:'',constraintDate:pd(t.querySelector('ConstraintDate')?.textContent),
      hasConstraint:hasCon,isCritical:t.querySelector('Critical')?.textContent==='1',
      predecessors:[],successors:[],resources:[],_scopeTag:''
    };
    taskMap[id]=act;activities.push(act);
  });
  const rels=[];
  all('Task').forEach(t=>{
    const succId=t.querySelector('UID')?.textContent;
    t.querySelectorAll('PredecessorLink').forEach(p=>{
      const predId=p.querySelector('PredecessorUID')?.textContent;
      const type=p.querySelector('Type')?.textContent||'1';
      const lag=parseFloat(p.querySelector('LinkLag')?.textContent||'0')/4800;
      const typeMap={'0':'FF','1':'FS','2':'SF','3':'SS'};
      rels.push({predId,succId,type:typeMap[type]||'FS',lag:pf(lag)});
    });
  });
  return buildSchedule({projectName:projName,projectId:'',dataDate,projStart,projFinish,activities,rels,calRows:[]});
}
function parseP6XML(doc){
  const projName=doc.querySelector('Project>Name')?.textContent||'P6 XML Project';
  const dataDate=pd(doc.querySelector('Project>DataDate')?.textContent||doc.querySelector('Project>LastRecalcDate')?.textContent);
  const projStart=pd(doc.querySelector('Project>PlannedStartDate')?.textContent||doc.querySelector('Project>ScheduledStartDate')?.textContent);
  const projFinish=pd(doc.querySelector('Project>MustFinishByDate')?.textContent||doc.querySelector('Project>ScheduledFinishDate')?.textContent||doc.querySelector('Project>AnticipatedFinishDate')?.textContent);
  const wbsMap={};
  [...doc.querySelectorAll('WBS')].forEach(w=>{const id=w.querySelector('ObjectId')?.textContent;const nm=w.querySelector('Name')?.textContent;if(id)wbsMap[id]=nm||id;});
  const activities=[...doc.querySelectorAll('Activity')].map(a=>{
    const id=a.querySelector('ObjectId')?.textContent||'';
    const dur=parseFloat(a.querySelector('PlannedDuration')?.textContent||'0')/8;
    const tf=parseFloat(a.querySelector('TotalFloat')?.textContent||'0')/8;
    const pct=parseFloat(a.querySelector('PhysicalPercentComplete')?.textContent||a.querySelector('PercentComplete')?.textContent||'0');
    const sc=a.querySelector('Status')?.textContent||'Not Started';
    let status='Not started';
    if(sc==='Completed'||sc==='TK_Complete') status='Completed';
    else if(sc==='In Progress'||sc==='TK_Active') status='In progress';
    const isMile=a.querySelector('Type')?.textContent?.includes('Milestone')||dur===0;
    const ct=a.querySelector('PrimaryConstraintType')?.textContent||'';
    return{
      id,actId:a.querySelector('Id')?.textContent||id,
      name:a.querySelector('Name')?.textContent||'(unnamed)',
      wbs:wbsMap[a.querySelector('WBSObjectId')?.textContent||'']||'Unassigned',
      duration:pf(dur),
      earlyStart:pd(a.querySelector('StartDate')?.textContent||a.querySelector('PlannedStartDate')?.textContent),
      earlyFinish:pd(a.querySelector('FinishDate')?.textContent||a.querySelector('PlannedFinishDate')?.textContent),
      actualStart:pd(a.querySelector('ActualStartDate')?.textContent),
      actualFinish:pd(a.querySelector('ActualFinishDate')?.textContent),
      blStart:null,blFinish:null,
      totalFloat:pf(tf),pct,status,
      type:isMile?'Milestone':'Task',
      constraintType:ct,constraintDate:pd(a.querySelector('PrimaryConstraintDate')?.textContent),
      hasConstraint:ct&&ct!=='As Late As Possible'&&ct!=='Start On Or After',
      isCritical:parseFloat(a.querySelector('TotalFloat')?.textContent||'1')<=0,
      predecessors:[],successors:[],resources:[],_scopeTag:''
    };
  });
  const rels=[...doc.querySelectorAll('Relationship')].map(r=>({
    predId:r.querySelector('PredecessorActivityObjectId')?.textContent||'',
    succId:r.querySelector('SuccessorActivityObjectId')?.textContent||'',
    type:r.querySelector('Type')?.textContent?.replace('Finish to Start','FS').replace('Start to Start','SS').replace('Finish to Finish','FF').replace('Start to Finish','SF')||'FS',
    lag:parseFloat(r.querySelector('Lag')?.textContent||'0')/8
  }));
  return buildSchedule({projectName:projName,projectId:'',dataDate,projStart,projFinish,activities,rels,calRows:[]});
}

